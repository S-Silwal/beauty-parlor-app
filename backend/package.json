{
  "name": "beauty-parlor-backend",
  "version": "1.0.0",
  "description": "Backend for Lumina Beauty Parlor",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node src/server.ts",
    "dev:watch": "nodemon --exec ts-node src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "start:prod": "npm run build && npm run start",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:push": "prisma db push",
    "prisma:reset": "prisma migrate reset",
    "db:seed": "ts-node src/utils/seed.ts",
    "db:reset": "npm run prisma:reset && npm run prisma:generate && npm run prisma:migrate && npm run db:seed",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix"
  },
  "prisma": {
    "seed": "ts-node src/utils/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@upstash/qstash": "^2.11.0",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.10.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "resend": "^6.12.3",
    "socket.io": "^4.8.3",
    "twilio": "^6.0.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-rate-limit": "^5.1.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.14.0",
    "@types/socket.io": "^3.0.1",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "nodemon": "^3.1.4",
    "prisma": "^5.15.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
